<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default: site.defaultTitle }}</title>
    <meta name="description" content="{{ description | default: site.defaultDescription }}">
    <meta name="robots" content="{{ robots | default: 'index, follow' }}">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    <link rel="alternate" hreflang="en" href="{{ site.url }}{{ page.url }}">
    <link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ page.url }}">

    <meta property="og:type" content="website">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:locale" content="en_US">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:title" content="{{ title | default: site.defaultTitle }}">
    <meta property="og:description" content="{{ description | default: site.defaultDescription }}">
    <meta property="og:image" content="{{ ogImage | default: site.ogImage }}">
    <meta property="og:image:alt" content="{{ ogImageAlt | default: site.ogImageAlt }}">

    <meta name="twitter:card" content="{{ site.twitterCard }}">
    <meta name="twitter:title" content="{{ title | default: site.defaultTitle }}">
    <meta name="twitter:description" content="{{ description | default: site.defaultDescription }}">
    <meta name="twitter:image" content="{{ ogImage | default: site.ogImage }}">
    <meta name="twitter:image:alt" content="{{ ogImageAlt | default: site.ogImageAlt }}">

    {% if site.googleSiteVerification != blank %}
      <meta name="google-site-verification" content="{{ site.googleSiteVerification }}">
    {% endif %}
    {% if site.bingSiteVerification != blank %}
      <meta name="msvalidate.01" content="{{ site.bingSiteVerification }}">
    {% endif %}

    <link rel="icon" href="/assets/logo.webp">
    {% if page.url == "/" %}
      <link rel="preload" href="/assets/home_img_01.webp" as="image" fetchpriority="high">
      <link rel="preload" href="/assets/game-play.webp" as="image" fetchpriority="high">
    {% endif %}
    <link rel="stylesheet" href="/assets/site.css">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2590716013793193" crossorigin="anonymous"></script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-X67H2NW4V5"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-X67H2NW4V5');
    </script>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "{{ site.name | escape }}",
        "url": "{{ site.url }}",
        "description": "{{ site.defaultDescription | escape }}",
        "inLanguage": "en"
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "name": "{{ title | default: site.defaultTitle | escape }}",
        "url": "{{ site.url }}{{ page.url }}",
        "description": "{{ description | default: site.defaultDescription | escape }}",
        "inLanguage": "en",
        "isPartOf": {
          "@type": "WebSite",
          "name": "{{ site.name | escape }}",
          "url": "{{ site.url }}"
        }
      }
    </script>
    {% if page.url == "/" %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "VideoGame",
        "name": "The Freak Circus",
        "description": "An 18+ psychological horror visual novel with route-sensitive progression, romance tension, and save-heavy replay planning.",
        "genre": [
          "Psychological Horror",
          "Visual Novel",
          "Romance"
        ],
        "playMode": "SinglePlayer",
        "gamePlatform": [
          "Web Browser",
          "Windows",
          "macOS",
          "Linux"
        ],
        "inLanguage": "en",
        "image": "{{ ogImage | default: site.ogImage }}",
        "url": "https://garula.itch.io/the-freak-circus"
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Where should I start if I want a spoiler-safe run?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Start with the official build, then use the guide path and route planner before reading deeper character or ending pages."
            }
          },
          {
            "@type": "Question",
            "name": "How should I organize saves for all endings?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Keep at least three route-intent saves and duplicate before any scene that feels emotionally decisive or tent-specific."
            }
          },
          {
            "@type": "Question",
            "name": "What if I only care about Pierrot or Harlequin?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Go straight to the character path cards above, then use the route hub to set up focused saves instead of replaying blindly."
            }
          }
        ]
      }
    </script>
    {% endif %}
    {% unless page.url == "/" %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ site.url }}"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "{{ title | default: site.defaultTitle | escape }}",
            "item": "{{ site.url }}{{ page.url }}"
          }
        ]
      }
    </script>
    {% endunless %}
    {% if page.url == "/play-online/" %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": "How to play The Freak Circus online through official access",
        "description": "Use official itch.io access paths to play or locate the current browser or download options for The Freak Circus.",
        "inLanguage": "en",
        "totalTime": "PT3M",
        "step": [
          {
            "@type": "HowToStep",
            "position": 1,
            "name": "Open the official itch.io game page",
            "text": "Visit the official The Freak Circus itch.io listing rather than a third-party mirror or copied search result."
          },
          {
            "@type": "HowToStep",
            "position": 2,
            "name": "Check whether browser play is currently offered",
            "text": "Look for browser or play-now options on the official page, and if those are unavailable use the official download path instead."
          },
          {
            "@type": "HowToStep",
            "position": 3,
            "name": "Follow official routing only",
            "text": "Use official links from the creator page or devlog and avoid suspicious mirrors, copied hosts, or unauthorized redistributions."
          }
        ]
      }
    </script>
    {% endif %}
    {% if page.url == "/guide/" %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": "How to start The Freak Circus without getting lost",
        "description": "A spoiler-aware beginner sequence for starting The Freak Circus, choosing official access, and making better first-run saves.",
        "inLanguage": "en",
        "step": [
          {
            "@type": "HowToStep",
            "position": 1,
            "name": "Use official access first",
            "text": "Start from the official play or download path before relying on random third-party search results."
          },
          {
            "@type": "HowToStep",
            "position": 2,
            "name": "Keep your first run mostly spoiler-safe",
            "text": "Avoid jumping straight into full ending optimization if you still want surprise from character and route reveals."
          },
          {
            "@type": "HowToStep",
            "position": 3,
            "name": "Make better saves early",
            "text": "Keep a main blind-run save, then duplicate before emotionally decisive scenes or route-heavy branches."
          }
        ]
      }
    </script>
    {% endif %}
    {% if page.url == "/faq/" %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is this the official site?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No. This is an independent guide site, and outbound links are kept focused on the official itch.io page and the creator's devlog."
            }
          },
          {
            "@type": "Question",
            "name": "Can I play directly on this site?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No. This site does not host playable builds or mirror copies. Use the Play Online page for official access guidance."
            }
          },
          {
            "@type": "Question",
            "name": "Is the game free?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Check the official itch.io page for the current pricing or payment model."
            }
          },
          {
            "@type": "Question",
            "name": "Where should I check Day 2 updates?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The creator's devlog should be treated as the primary source for Day 2 updates."
            }
          },
          {
            "@type": "Question",
            "name": "Where should I go for endings or route help?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Use the endings page, routes page, character pages, or the Day 2 update page depending on how much spoiler detail you want."
            }
          }
        ]
      }
    </script>
    {% endif %}
  </head>
  <body>
    <header class="site-header" data-header>
      <div class="container header-content">
        <a class="brand" href="/">
          <img class="brand-logo" src="/assets/logo.webp" alt="The Freak Circus logo" width="48" height="48">
          <span class="brand-text">The Freak Circus</span>
        </a>

        <nav class="desktop-nav" aria-label="Primary">
          <a href="/">Home</a>
          <div class="nav-dropdown">
            <button class="nav-dropdown-toggle" type="button" aria-expanded="false">Characters</button>
            <div class="nav-dropdown-menu">
              <a href="/pierrot">Pierrot</a>
              <a href="/harlequin">Harlequin</a>
              <a href="/jester">Jester</a>
              <a href="/doctor">Doctor</a>
              <a href="/ticket-taker">Ticket Taker</a>
            </div>
          </div>
          <a href="/routes">Routes</a>
          <a href="/endings">Endings</a>
          <a href="/wiki">Wiki</a>
          <a href="/updates">Updates</a>
          <a href="/download">Download</a>
        </nav>

        <button class="mobile-menu-button" type="button" aria-expanded="false" aria-controls="mobile-nav" data-mobile-toggle>
          <span></span>
          <span></span>
          <span></span>
          <span class="sr-only">Open menu</span>
        </button>
      </div>

      <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile">
        <a href="/">Home</a>
        <a href="/pierrot">Pierrot</a>
        <a href="/harlequin">Harlequin</a>
        <a href="/jester">Jester</a>
        <a href="/doctor">Doctor</a>
        <a href="/ticket-taker">Ticket Taker</a>
        <a href="/routes">Routes</a>
        <a href="/endings">Endings</a>
        <a href="/wiki">Wiki</a>
        <a href="/updates">Updates</a>
        <a href="/download">Download</a>
      </nav>
    </header>

    {% if page.url == "/" %}
      <main>
        {{ content }}
      </main>
    {% else %}
      <main class="content-page">
        <section class="content-hero">
          <div class="container">
            <p class="eyebrow">The Freak Circus Guide</p>
            <h1>{{ title }}</h1>
            {% if description %}
              <p class="content-lead">{{ description }}</p>
            {% endif %}
          </div>
        </section>

        <section class="content-body">
          <div class="container">
            <article class="content-panel prose">
              {{ content }}
            </article>
          </div>
        </section>
      </main>
    {% endif %}

    <footer class="site-footer">
      <div class="container footer-grid">
        <section>
          <div class="footer-brand">
            <img src="/assets/logo.webp" alt="The Freak Circus logo" width="48" height="48">
            <h2>The Freak Circus</h2>
          </div>
          <p>Dive into a twisted circus world where obsession, rivalry, and psychological horror collide.</p>
        </section>

        <section>
          <h2>Quick Links</h2>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/routes">Routes</a></li>
            <li><a href="/endings">Endings</a></li>
            <li><a href="/pierrot">Pierrot</a></li>
            <li><a href="/harlequin">Harlequin</a></li>
            <li><a href="/wiki">Wiki</a></li>
            <li><a href="/updates">Updates</a></li>
            <li><a href="/download">Download</a></li>
          </ul>
        </section>

        <section>
          <h2>Legal</h2>
          <ul>
            <li><a href="/cookie-policy">Cookie Policy</a></li>
            <li><a href="/privacy-policy">Privacy Policy</a></li>
            <li><a href="/terms-of-service">Terms of Service</a></li>
            <li><a href="/copyright">Copyright</a></li>
            <li><a href="/about-us">About Us</a></li>
            <li><a href="/contact-us">Contact Us</a></li>
          </ul>
        </section>
      </div>

      <div class="container footer-bottom">
        <p>© 2026 The Freak Circus Walkthrough Hub.</p>
        <p class="footer-note">Built as an independent player guide focused on route prep, ending planning, and official access points.</p>
      </div>
    </footer>

    <script defer src="/assets/site.js"></script>
    <script defer src="/assets/embed.js"></script>
  </body>
</html>
